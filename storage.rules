rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isChatMember(roomId) {
      return signedIn() &&
          request.auth.uid in firestore.get(
            /databases/(default)/documents/chatRooms/$(roomId)
          ).data.members;
    }

    match /users/{userId}/profile.jpg {
      allow read: if signedIn();
      allow write: if signedIn()
                   && request.auth.uid == userId
                   && request.resource.contentType == 'image/jpeg'
                   && request.resource.size <= 5 * 1024 * 1024;
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/{allPaths=**} {
      allow read, write: if false;
    }

    match /chatRooms/{roomId}/photo.jpg {
      allow read: if signedIn();
      allow write: if isChatMember(roomId)
                   && request.resource.contentType == 'image/jpeg'
                   && request.resource.size <= 5 * 1024 * 1024;
      allow delete: if isChatMember(roomId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
